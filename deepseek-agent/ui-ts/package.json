{
  "name": "deepseek-agent-ui",
  "version": "2.0.0",
  "description": "DeepSeek Security Agent — Electron terminal with 3D mask",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps 2>/dev/null || true",
    "dev": "node scripts/dev.js",
    "build": "tsc -p tsconfig.vite.json --noEmit && vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "preview": "vite preview",
    "ds": "node scripts/ds.js"
  },
  "bin": {
    "ds": "./scripts/ds.js"
  },
  "dependencies": {
    "three": "^0.165.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/three": "^0.165.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.0"
  }
}
