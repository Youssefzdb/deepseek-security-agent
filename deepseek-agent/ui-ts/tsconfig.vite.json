{
  "compilerOptions": {
    "target":    "ES2020",
    "module":    "ESNext",
    "moduleResolution": "bundler",
    "lib":       ["ES2020", "DOM", "DOM.Iterable"],
    "strict":    true,
    "noImplicitAny": true,
    "outDir":    "dist/renderer",
    "rootDir":   "src",
    "declaration":    false,
    "sourceMap":      true,
    "esModuleInterop": true,
    "skipLibCheck":   true
  },
  "include": ["src/**/*"]
}
